<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ZEC Payroll - Unlock</title>
  <link rel="stylesheet" href="/style.css">
  <script>
    (function() {
      var t = localStorage.getItem('zec-theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>
</head>
<body>
  <div class="unlock-page">
    <div class="unlock-icon">
      <svg width="44" height="44" viewBox="0 0 24 24" fill="none" stroke="#f4b728" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <path d="M7 11V7a5 5 0 0110 0v4"/>
        <circle cx="12" cy="16.5" r="1.5"/>
      </svg>
    </div>
    <h1>ZEC Payroll</h1>
    <p class="unlock-desc">Shielded payroll with ZIP-321 payment URIs.</p>

    <% if (error) { %>
      <div class="msg msg-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/unlock" class="unlock-form">
      <input type="password" name="passphrase" placeholder="Enter passphrase" required autofocus>
      <button type="submit">Unlock</button>
    </form>

    <p class="unlock-note">Your passphrase decrypts payroll data locally. First use sets the passphrase. No recovery if forgotten.</p>
  </div>
</body>
</html>
